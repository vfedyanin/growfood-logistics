generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============================================================
//  ПОЛЬЗОВАТЕЛИ, РОЛИ, ПРАВА (табличный RBAC сохранён)
// ============================================================

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  fullName     String
  phone        String?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  roles               UserRole[]
  sessions            Session[]
  reportedQualityEvts QualityEvent[]
  auditLogs           AuditLog[]
}

model Role {
  id          String  @id @default(cuid())
  name        String  @unique // ADMIN, LOGISTICS_MANAGER, LAAS_MANAGER, OWN_DISPATCHER, WAREHOUSE_OPERATOR, RECEIVER_OPERATOR, ACCOUNTANT, VIEWER
  description String?

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id       String @id @default(cuid())
  code     String @unique
  name     String
  category String

  roles RolePermission[]
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId])
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@unique([roleId, permissionId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ============================================================
//  СПРАВОЧНИКИ
// ============================================================

// Чистый справочник — без полей аудита (по ТЗ)
model Vertical {
  code     String       @id // GROWFOOD, LAAS, RETAIL, PRIEM, VENDING
  name     String
  type     VerticalType
  isActive Boolean      @default(true)

  customers      Customer[]
  trips          Trip[]
  tripCargoUnits TripCargoUnit[]
  requests       CustomerRequest[]
}

enum VerticalType {
  INTERNAL
  EXTERNAL
}

model Location {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  type        LocationType
  ownerType   LocationOwnerType
  city        String?
  region      String?
  address     String?
  lat         Decimal?          @db.Decimal(9, 6)
  lon         Decimal?          @db.Decimal(9, 6)
  isActive    Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdById String?
  updatedById String?

  routesAsOrigin      Route[]           @relation("RouteOrigin")
  routesAsDestination Route[]           @relation("RouteDestination")
  tripsAsOrigin       Trip[]            @relation("TripOrigin")
  tripsAsDestination  Trip[]            @relation("TripDestination")
  customerDeliveries  CustomerDeliveryLocation[]
  legsAsOrigin        TripLeg[]         @relation("LegOrigin")
  legsAsDestination   TripLeg[]         @relation("LegDestination")
  requestsAsPickup    CustomerRequest[] @relation("ReqPickup")
  requestsAsDelivery  CustomerRequest[] @relation("ReqDelivery")
  reqLegAsPickup      RequestCargoLeg[] @relation("RCLPickup")
  reqLegAsDropoff     RequestCargoLeg[] @relation("RCLDropoff")
  reqCargoAsConsignee RequestCargo[]    @relation("RCConsigneeLocation")
}

enum LocationType {
  WAREHOUSE
  HUB
  KITCHEN
  DC
  RETAIL_POINT
  FACTORY
}

enum LocationOwnerType {
  OWN
  CUSTOMER
  PARTNER
}

model Customer {
  id            String       @id @default(cuid())
  code          String       @unique
  name          String
  inn           String?      @unique
  kpp           String?
  fullLegalName String?
  verticalCode  String
  customerType  CustomerType
  partyRole     PartyRole    @default(BOTH)
  contactPerson String?
  phone         String?
  email         String?
  isActive      Boolean      @default(true)
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   String?
  updatedById   String?

  vertical Vertical @relation(fields: [verticalCode], references: [code])

  contracts           CustomerContract[]
  ownedCargoUnits     CargoUnit[]
  tripsAsShipper      Trip[]             @relation("TripShipper")
  tripsAsConsignee    Trip[]             @relation("TripConsignee")
  tripsAsPayer        Trip[]             @relation("TripPayer")
  tcuAsCustomer       TripCargoUnit[]    @relation("TCUCustomer")
  tcuAsShipper        TripCargoUnit[]    @relation("TCUShipper")
  requestsAsCustomer  CustomerRequest[]  @relation("ReqCustomer")
  requestsAsShipper   CustomerRequest[]  @relation("ReqShipper")
  requestsAsConsignee CustomerRequest[]  @relation("ReqConsignee")
  requestsAsPayer     CustomerRequest[]  @relation("ReqPayer")
  reqCargoAsConsignee RequestCargo[]     @relation("RCConsignee")
  acts                CustomerAct[]
  invoices            Invoice[]
  payments            Payment[]
  deliveryLocations   CustomerDeliveryLocation[]
  contractMemberships CustomerContractMember[]
}

model CustomerDeliveryLocation {
  id           String         @id @default(cuid())
  customerId   String
  locationId   String
  tariffMethod TariffMethod?
  tariffAmount Decimal?       @db.Decimal(10, 2)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  location Location  @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([customerId, locationId])
  @@index([customerId])
}

enum TariffMethod {
  PER_PALLET
  PER_TRIP
}

enum CustomerType {
  INTERNAL
  RETAIL_CHAIN
  EXTERNAL_COMPANY
}

enum PartyRole {
  SHIPPER
  CONSIGNEE
  BOTH
}

model Carrier {
  id            String   @id @default(cuid())
  code          String   @unique
  name          String
  inn           String?
  kpp           String?
  contactPerson String?
  phone         String?
  email         String?
  isActive      Boolean  @default(true)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?
  updatedById   String?

  vehicles  Vehicle[]
  drivers   Driver[]
  contracts CarrierContract[]
  trips     Trip[]
  acts      CarrierAct[]
  invoices  Invoice[]
  payments  Payment[]
}

// Чистый справочник — без полей аудита (по ТЗ)
model VehicleType {
  code            String   @id // VAN_3T, TRUCK_5T, TRUCK_10T, TRUCK_20T, REF_3T, REF_5T, REF_10T, REF_20T
  name            String
  capacityKg      Decimal? @db.Decimal(10, 2)
  capacityPallets Int?
  isRefrigerator  Boolean  @default(false)

  vehicles     Vehicle[]
  tariffs      Tariff[]
  marketPrices MarketPrice[]
  trips        Trip[]        @relation("TripVehicleType")
  tariffTiers  TariffTier[]
}

model AdditionalService {
  code      String   @id // WAIT, RETURN, FORKLIFT, ESCORT, …
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Vehicle {
  id              String   @id @default(cuid())
  plateNumber     String   @unique
  brandModel      String?
  vehicleTypeCode String
  carrierId       String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdById     String?
  updatedById     String?

  vehicleType VehicleType @relation(fields: [vehicleTypeCode], references: [code])
  carrier     Carrier?    @relation(fields: [carrierId], references: [id])
  trips       Trip[]
}

model Driver {
  id            String   @id @default(cuid())
  fullName      String
  phone         String?
  licenseNumber String?
  carrierId     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?
  updatedById   String?

  carrier Carrier? @relation(fields: [carrierId], references: [id])
  trips   Trip[]
}

// ============================================================
//  КОНТРАКТЫ И ТАРИФЫ
// ============================================================

model CustomerContract {
  id             String       @id @default(cuid())
  contractNumber String
  customerId     String
  contractType   ContractType
  vatRatePct     Int          @default(0) // ставка НДС: 0(без НДС)/5/7/10/22
  validFrom      DateTime
  validTo        DateTime?
  paymentTerms   String?
  notes          String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  createdById    String?
  updatedById    String?

  customer Customer                  @relation(fields: [customerId], references: [id])
  tariffs  Tariff[]                  @relation("CustContractTariff")
  acts     CustomerAct[]
  members  CustomerContractMember[]
}

model CustomerContractMember {
  contractId String
  customerId String

  contract CustomerContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  customer Customer         @relation(fields: [customerId], references: [id])

  @@id([contractId, customerId])
}

enum ContractType {
  LAAS_SERVICE
  RETAIL_SUPPLY
  INTERNAL_AGREEMENT
}

model CarrierContract {
  id             String    @id @default(cuid())
  contractNumber String
  carrierId      String
  vatRatePct     Int       @default(0) // ставка НДС: 0(без НДС)/5/7/10/22
  validFrom      DateTime
  validTo        DateTime?
  paymentTerms   String?
  notes          String?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?

  carrier Carrier  @relation(fields: [carrierId], references: [id])
  tariffs Tariff[] @relation("CarrContractTariff")
}

// Полиморфизм: ровно один из customerContractId / carrierContractId NOT NULL
// (CHECK-констрейнт добавляется отдельным SQL после db push)
model Tariff {
  id                 String       @id @default(cuid())
  customerContractId String?
  carrierContractId  String?
  routeId            String?
  vehicleTypeCode    String?
  tariffType         TariffMethod @default(PER_PALLET)
  pricePerTrip       Decimal?     @db.Decimal(12, 2)
  pricePerPallet     Decimal?     @db.Decimal(12, 2)
  pricePerKm         Decimal?     @db.Decimal(8, 2)
  validFrom          DateTime
  validTo            DateTime?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  createdById        String?
  updatedById        String?

  customerContract CustomerContract? @relation("CustContractTariff", fields: [customerContractId], references: [id])
  carrierContract  CarrierContract?  @relation("CarrContractTariff", fields: [carrierContractId], references: [id])
  route            Route?            @relation(fields: [routeId], references: [id])
  vehicleType      VehicleType?      @relation(fields: [vehicleTypeCode], references: [code])
  tiers            TariffTier[]
}

model TariffTier {
  id              String  @id @default(cuid())
  tariffId        String
  vehicleTypeCode String
  price           Decimal @db.Decimal(12, 2)

  tariff      Tariff      @relation(fields: [tariffId], references: [id], onDelete: Cascade)
  vehicleType VehicleType @relation(fields: [vehicleTypeCode], references: [code])
}

model MarketPrice {
  id              String    @id @default(cuid())
  routeId         String
  vehicleTypeCode String
  pricePerTrip    Decimal?  @db.Decimal(12, 2)
  pricePerPallet  Decimal?  @db.Decimal(12, 2)
  pricePerKm      Decimal?  @db.Decimal(8, 2)
  validFrom       DateTime
  validTo         DateTime?
  source          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdById     String?
  updatedById     String?

  route       Route       @relation(fields: [routeId], references: [id])
  vehicleType VehicleType @relation(fields: [vehicleTypeCode], references: [code])
}

// ============================================================
//  МАРШРУТЫ
// ============================================================

model Route {
  id             String    @id @default(cuid())
  code           String    @unique
  name           String?
  originId       String
  destinationId  String
  distanceKm     Decimal?  @db.Decimal(10, 2)
  estimatedHours Decimal?  @db.Decimal(5, 2)
  routeType      RouteType
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdById    String?
  updatedById    String?

  origin       Location      @relation("RouteOrigin", fields: [originId], references: [id])
  destination  Location      @relation("RouteDestination", fields: [destinationId], references: [id])
  trips        Trip[]
  tariffs      Tariff[]
  marketPrices MarketPrice[]
}

enum RouteType {
  DIRECT
  HUB
  MILK_RUN
}

// ============================================================
//  ТРАНЗАКЦИОННЫЕ
// ============================================================

model Trip {
  id               String     @id @default(cuid())
  tripNumber       String     @unique
  tripType         TripType
  verticalCode     String?
  routeId          String?
  originId         String?
  destinationId    String?
  vehicleTypeCode  String?
  vehicleId        String?
  driverId         String?
  carrierId        String?
  shipperId        String?
  consigneeId      String?
  payerId          String?
  plannedDeparture DateTime?
  plannedArrival   DateTime?
  actualDeparture  DateTime?
  actualArrival    DateTime?
  plannedPallets   Int?
  actualPallets    Int?
  plannedWeightKg  Decimal?   @db.Decimal(10, 2)
  actualWeightKg   Decimal?   @db.Decimal(10, 2)
  actualCost       Decimal?   @db.Decimal(12, 2)
  vatRatePct       Int?       @default(0)
  status           TripStatus @default(DRAFT)
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  createdById      String?
  updatedById      String?

  vertical    Vertical? @relation(fields: [verticalCode], references: [code])
  route       Route?    @relation(fields: [routeId], references: [id])
  origin       Location?    @relation("TripOrigin", fields: [originId], references: [id])
  destination  Location?    @relation("TripDestination", fields: [destinationId], references: [id])
  vehicleType  VehicleType? @relation("TripVehicleType", fields: [vehicleTypeCode], references: [code])
  vehicle      Vehicle?     @relation(fields: [vehicleId], references: [id])
  driver      Driver?   @relation(fields: [driverId], references: [id])
  carrier     Carrier?  @relation(fields: [carrierId], references: [id])
  shipper     Customer? @relation("TripShipper", fields: [shipperId], references: [id])
  consignee   Customer? @relation("TripConsignee", fields: [consigneeId], references: [id])
  payer       Customer? @relation("TripPayer", fields: [payerId], references: [id])

  legs          TripLeg[]
  cargoUnits    TripCargoUnit[]
  qualityEvents QualityEvent[]
  actTripLinks  ActTripLink[]
  invoices      Invoice[]

  @@index([plannedDeparture])
  @@index([status])
  @@index([shipperId])
  @@index([consigneeId])
  @@index([payerId])
  @@index([carrierId])
}

enum TripType {
  OWN
  LAAS
  CONSOLIDATED
}

enum TripStatus {
  DRAFT
  PLANNED
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model TripLeg {
  id               String    @id @default(cuid())
  tripId           String
  legOrder         Int
  originId         String
  destinationId    String
  plannedDeparture DateTime?
  plannedArrival   DateTime?
  actualDeparture  DateTime?
  actualArrival    DateTime?
  distanceKm       Decimal?  @db.Decimal(10, 2)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdById      String?
  updatedById      String?

  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  origin      Location @relation("LegOrigin", fields: [originId], references: [id])
  destination Location @relation("LegDestination", fields: [destinationId], references: [id])

  @@index([tripId])
}

model CargoUnit {
  id              String        @id @default(cuid())
  barcode         String?       @unique
  unitType        CargoUnitType
  ownerCustomerId String?
  palletType      PalletType?
  isReturnable    Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdById     String?
  updatedById     String?

  owner          Customer?       @relation(fields: [ownerCustomerId], references: [id])
  tripCargoUnits TripCargoUnit[]
}

enum CargoUnitType {
  PALLET
  BOX
  CARTON
}

enum PalletType {
  EURO
  AMERICAN
  STANDARD
}

model TripCargoUnit {
  id              String           @id @default(cuid())
  tripId          String
  cargoUnitId     String?
  verticalCode    String?
  customerId      String?
  shipperId       String?
  unitType        CargoUnitType
  pallets         Int?
  boxes           Int?
  traysCount      Int?
  weightKg        Decimal?         @db.Decimal(10, 2)
  productCategory ProductCategory?
  tempRegime      TempRegime?
  tempRequiredMin Decimal?         @db.Decimal(4, 1)
  tempRequiredMax Decimal?         @db.Decimal(4, 1)
  requestId       String?
  notes           String?
  costSharePct    Decimal?         @db.Decimal(7, 4)
  allocatedCost   Decimal?         @db.Decimal(12, 2)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?
  updatedById     String?

  trip            Trip             @relation(fields: [tripId], references: [id], onDelete: Cascade)
  cargoUnit       CargoUnit?       @relation(fields: [cargoUnitId], references: [id])
  vertical        Vertical?        @relation(fields: [verticalCode], references: [code])
  customer        Customer?        @relation("TCUCustomer", fields: [customerId], references: [id])
  shipper         Customer?        @relation("TCUShipper", fields: [shipperId], references: [id])
  request         CustomerRequest? @relation(fields: [requestId], references: [id])
  requestCargoLeg RequestCargoLeg?

  @@index([tripId])
}

enum ProductCategory {
  READY_FOOD
  RAW
  EQUIPMENT
  CONFECTIONERY
  OTHER
}

enum TempRegime {
  FROZEN
  COOLED
  AMBIENT
}

model CustomerRequest {
  id                 String           @id @default(cuid())
  requestNumber      String           @unique
  customerId         String
  payerId            String?
  verticalCode       String?
  shipperId          String?
  consigneeId        String?
  pickupLocationId   String?
  deliveryLocationId String?
  requestDate        DateTime?
  pickupDate         DateTime?
  pickupTimeFrom     String?
  pickupTimeTo       String?
  deliveryDate       DateTime?
  deliveryTimeFrom   String?
  deliveryTimeTo     String?
  requestedPallets   Int?
  requestedWeightKg  Decimal?         @db.Decimal(10, 2)
  traysCount         Int?
  productCategory    ProductCategory?
  tempRegime         TempRegime?
  status             RequestStatus    @default(NEW)
  perTripScope       PerTripScope     @default(CARGO)
  notes              String?
  clientUpd          String?
  transportNote      String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdById        String?
  updatedById        String?

  parentRequestId  String?
  parent           CustomerRequest?  @relation("RequestGroup", fields: [parentRequestId], references: [id], onDelete: SetNull)
  groupChildren    CustomerRequest[] @relation("RequestGroup")

  customer         Customer       @relation("ReqCustomer", fields: [customerId], references: [id])
  payer            Customer?      @relation("ReqPayer", fields: [payerId], references: [id])
  vertical         Vertical?      @relation(fields: [verticalCode], references: [code])
  shipper          Customer?      @relation("ReqShipper", fields: [shipperId], references: [id])
  consignee        Customer?      @relation("ReqConsignee", fields: [consigneeId], references: [id])
  pickupLocation   Location?      @relation("ReqPickup", fields: [pickupLocationId], references: [id])
  deliveryLocation Location?      @relation("ReqDelivery", fields: [deliveryLocationId], references: [id])
  cargoes          RequestCargo[]
  invoices         Invoice[]

  tripCargoUnits TripCargoUnit[]
}

enum RequestStatus {
  NEW
  CONFIRMED
  IN_PLANNING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model QualityEvent {
  id                 String           @id @default(cuid())
  tripId             String
  eventType          QualityEventType
  severity           Severity
  eventTime          DateTime?
  tempRecorded       Decimal?         @db.Decimal(4, 1)
  tempRequiredMin    Decimal?         @db.Decimal(4, 1)
  tempRequiredMax    Decimal?         @db.Decimal(4, 1)
  delayMinutes       Int?
  description        String?
  reportedById       String?
  photoUrls          String[]
  compensationAmount Decimal?         @db.Decimal(12, 2)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  createdById        String?
  updatedById        String?

  trip       Trip  @relation(fields: [tripId], references: [id], onDelete: Cascade)
  reportedBy User? @relation(fields: [reportedById], references: [id])

  @@index([tripId])
}

enum QualityEventType {
  LATE_DEPARTURE
  LATE_ARRIVAL
  TEMP_VIOLATION
  CARGO_DAMAGE
  ROUTE_DEVIATION
  VEHICLE_BREAKDOWN
  DOCUMENTATION_ISSUE
}

enum Severity {
  MINOR
  MAJOR
  CRITICAL
}

// ============================================================
//  ФИНАНСЫ (унифицированные Invoice / Payment / ActTripLink)
// ============================================================

model CustomerAct {
  id          String            @id @default(cuid())
  actNumber   String            @unique
  customerId  String
  contractId  String?
  periodFrom  DateTime
  periodTo    DateTime
  totalAmount Decimal           @db.Decimal(14, 2)
  vatRatePct  Int?
  status      CustomerActStatus @default(DRAFT)
  fileUrl     String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdById String?
  updatedById String?

  customer     Customer          @relation(fields: [customerId], references: [id])
  contract     CustomerContract? @relation(fields: [contractId], references: [id])
  actTripLinks ActTripLink[]     @relation("CustActLink")
  invoices     Invoice[]
}

enum CustomerActStatus {
  DRAFT
  SENT
  SIGNED
  REJECTED
}

model CarrierAct {
  id          String           @id @default(cuid())
  actNumber   String           @unique
  carrierId   String
  periodFrom  DateTime
  periodTo    DateTime
  totalAmount Decimal          @db.Decimal(14, 2)
  vatRatePct  Int?
  status      CarrierActStatus @default(DRAFT)
  fileUrl     String?
  notes       String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdById String?
  updatedById String?

  carrier      Carrier       @relation(fields: [carrierId], references: [id])
  actTripLinks ActTripLink[] @relation("CarrActLink")
  invoices     Invoice[]
}

enum CarrierActStatus {
  DRAFT
  RECEIVED
  APPROVED
  REJECTED
}

model ActTripLink {
  id            String   @id @default(cuid())
  tripId        String
  customerActId String?
  carrierActId  String?
  amountInAct   Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdById   String?
  updatedById   String?

  trip        Trip         @relation(fields: [tripId], references: [id])
  customerAct CustomerAct? @relation("CustActLink", fields: [customerActId], references: [id])
  carrierAct  CarrierAct?  @relation("CarrActLink", fields: [carrierActId], references: [id])

  @@index([tripId])
}

model Invoice {
  id            String           @id @default(cuid())
  invoiceNumber String
  invoiceDate   DateTime
  direction     InvoiceDirection
  customerId    String?
  carrierId     String?
  customerActId String?
  carrierActId  String?
  requestId     String?
  tripId        String?
  carrierInvoiceNumber String?
  amount        Decimal          @db.Decimal(14, 2)
  vatAmount     Decimal?         @db.Decimal(14, 2)
  total         Decimal          @db.Decimal(14, 2)
  dueDate       DateTime?
  status        InvoiceStatus    @default(ISSUED)
  fileUrl       String?
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdById   String?
  updatedById   String?

  customer    Customer?        @relation(fields: [customerId], references: [id])
  carrier     Carrier?         @relation(fields: [carrierId], references: [id])
  customerAct CustomerAct?     @relation(fields: [customerActId], references: [id])
  carrierAct  CarrierAct?      @relation(fields: [carrierActId], references: [id])
  request     CustomerRequest? @relation(fields: [requestId], references: [id])
  trip        Trip?            @relation(fields: [tripId], references: [id])
  payments    Payment[]

  @@index([direction])
  @@index([status])
}

enum InvoiceDirection {
  OUTGOING
  INCOMING
}

enum InvoiceStatus {
  ISSUED
  SENT
  PAID
  PARTIAL
  OVERDUE
  CANCELLED
}

model Payment {
  id            String           @id @default(cuid())
  paymentDate   DateTime
  amount        Decimal          @db.Decimal(14, 2)
  direction     PaymentDirection
  customerId    String?
  carrierId     String?
  invoiceId     String?
  paymentMethod PaymentMethod    @default(BANK_TRANSFER)
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  createdById   String?
  updatedById   String?

  customer Customer? @relation(fields: [customerId], references: [id])
  carrier  Carrier?  @relation(fields: [carrierId], references: [id])
  invoice  Invoice?  @relation(fields: [invoiceId], references: [id])

  @@index([direction])
}

enum PaymentDirection {
  INCOMING
  OUTGOING
}

enum PaymentMethod {
  BANK_TRANSFER
  CASH
  OFFSET
}

// ============================================================
//  АУДИТ
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  entityType  String
  entityId    String
  beforeValue Json?
  afterValue  Json?
  createdAt   DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([userId])
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

// Шаблоны заполнения формы рейса (общие для всех пользователей)
model TripTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
}

// Грузы заявки (строки): точки забора/выгрузки, плановые даты, стоимость/скидка/итого
model RequestCargo {
  id              String           @id @default(cuid())
  requestId       String
  consigneeId             String?
  consigneeLocationId     String?
  unitType                CargoUnitType    @default(PALLET)
  pallets         Int?
  traysCount      Int?
  weightKg        Decimal?         @db.Decimal(10, 2)
  productCategory ProductCategory?
  tempRegime      TempRegime?
  pricingMode     CargoPricingMode @default(CARGO)
  cost            Decimal?         @db.Decimal(12, 2)
  discount        Decimal?         @db.Decimal(12, 2)
  finalCost       Decimal?         @db.Decimal(12, 2)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  createdById     String?
  updatedById     String?

  request           CustomerRequest   @relation(fields: [requestId], references: [id], onDelete: Cascade)
  consignee         Customer?         @relation("RCConsignee", fields: [consigneeId], references: [id])
  consigneeLocation Location?         @relation("RCConsigneeLocation", fields: [consigneeLocationId], references: [id])
  legs              RequestCargoLeg[]

  @@index([requestId])
}

enum CargoPricingMode {
  CARGO
  LEG
  TARIFF
}

// Как распределяется фикс-тариф PER_TRIP по грузам заявки:
// CARGO — полная ставка точки на каждый PER_TRIP-груз;
// REQUEST — одна сумма на заявку (Σ ставок уникальных точек ÷ число PER_TRIP-грузов).
enum PerTripScope {
  CARGO
  REQUEST
}

// Плечо маршрута груза: один отрезок забор→выгрузка, привязывается к своему рейсу
model RequestCargoLeg {
  id                String    @id @default(cuid())
  requestCargoId    String
  legOrder          Int       @default(1)
  pickupLocationId  String?
  dropoffLocationId String?
  plannedPickup     DateTime?
  plannedPickupTo   String?
  plannedDropoff    DateTime?
  plannedDropoffTo  String?
  cost              Decimal?  @db.Decimal(12, 2)
  discount          Decimal?  @db.Decimal(12, 2)
  finalCost         Decimal?  @db.Decimal(12, 2)
  tripCargoUnitId   String?   @unique
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  createdById       String?
  updatedById       String?

  cargo           RequestCargo   @relation(fields: [requestCargoId], references: [id], onDelete: Cascade)
  pickupLocation  Location?      @relation("RCLPickup", fields: [pickupLocationId], references: [id])
  dropoffLocation Location?      @relation("RCLDropoff", fields: [dropoffLocationId], references: [id])
  tripCargoUnit   TripCargoUnit? @relation(fields: [tripCargoUnitId], references: [id])

  @@index([requestCargoId])
}

// Шаблоны заполнения формы заявки
model RequestTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  data        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdById String?
  updatedById String?
}
